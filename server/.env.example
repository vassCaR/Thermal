# ============================================================================
# Ghost Tips server — environment
# Copy to .env and fill in keys. With MOCK=true you need NOTHING here to run.
# ============================================================================

# --- Master switch ---
MOCK=true                                     # true => in-memory mock adapters (default). false => real Unlink + Circle.

# --- Backend ---
PORT=8787
HOST=0.0.0.0
BATCH_INTERVAL_MS=4000                        # per-creator aggregation window before a settlement is attempted
CORS_ORIGINS=*                                # "*" (demo) or comma-separated origins, e.g. http://localhost:3000
LOG_LEVEL=info

# --- Arc / Circle (only needed when MOCK=false) ---
CHAIN_ENV=arc-testnet                         # logical chain/env tag forwarded to adapters
ARC_RPC_URL=https://rpc.testnet.arc.network   # verify exact Arc testnet RPC URL with Circle
CIRCLE_API_KEY=                               # Circle Developer (Nanopayments / Gateway)
CIRCLE_GATEWAY_URL=                           # Circle Gateway base URL for Arc testnet
USDC_ADDRESS=                                 # USDC testnet contract address on Arc
SETTLER_PRIVATE_KEY=                          # 0x-prefixed key of the relayer that settles on Arc

# --- Unlink (only needed when MOCK=false) ---
UNLINK_API_KEY=
UNLINK_ENV=testnet                            # Unlink environment string — CONFIRM exact value for Arc with Unlink DevRel
UNLINK_ENGINE_URL=                            # Unlink engine/API base URL used by the admin/low-level client
